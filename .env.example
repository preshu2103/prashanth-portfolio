# ============================================================
# Prashanth Bandi Portfolio — Environment Variables
# Copy this file as .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# Server
PORT=5000

# MongoDB Atlas URI
# Go to https://cloud.mongodb.com → Connect → Drivers → Copy URI
# Replace <password> and <dbname> with your values
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Gmail SMTP — Nodemailer
# Use your Gmail address
EMAIL_USER=prashanthchowdary1981@gmail.com
# IMPORTANT: Use an App Password, NOT your real Gmail password
# Go to: Google Account → Security → 2-Step Verification → App Passwords
# Generate a 16-character app password and paste it here
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Frontend URL (for CORS — your deployed frontend domain)
FRONTEND_URL=https://your-portfolio.vercel.app

# Node Environment
NODE_ENV=production
